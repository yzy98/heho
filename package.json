{
  "name": "heho",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source, self-hosted AI chatbots for company websites, with transparent RAG and bring-your-own LLM providers.",
  "keywords": [
    "ai",
    "chatbot",
    "rag",
    "self-hosted",
    "open-source",
    "website-widget",
    "llm",
    "typescript"
  ],
  "packageManager": "pnpm@10.33.2",
  "license": "LGPL-3.0-or-later",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm fix --"
    ]
  }
}
